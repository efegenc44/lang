fun main() -> Nat =
    fib(25)

fun fun_add(
    f1: fun(Real) -> Real,
    f2: fun(Real) -> Real
) -> fun(Real) -> Real =
    fun closure(x: Real) -> Real = 
        f1(x) + f2(x)
    in closure

fun fib(n: Int) -> Nat =
    (if n <= 2   return 1);
    fib(n - 1) + fib(n - 2)

fun factorial(n: Int) -> Int =
    if n == 1
        1
    else
        n * factorial(n - 1)