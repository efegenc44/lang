    { slot : a }

type Box2 = \a : * -> * \b : *
    { slot : a b }

type Box3 = \a : * -> * -> *  \b : * \c : * -> *
    { slot : Box4 a c b }

type Box4 = \a : * -> * -> * \b : * \c : * -> *
    { slot : a c b }

